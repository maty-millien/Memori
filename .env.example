# OpenRouter API key. Get one at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-replace-me

# Chat model used by the assistant. Any OpenRouter chat model that supports
MEMORI_LLM_MODEL=deepseek/deepseek-v4-flash

# Reasoning effort passed to the model. One of: low, medium, high.
MEMORI_REASONING_EFFORT=high

# Embedding model used by the vector store for memory retrieval.
MEMORI_EMBEDDING_MODEL=perplexity/pplx-embed-v1-4b

# Retrieval limits.
MEMORI_RETRIEVAL_TOP_K=20
MEMORI_RETRIEVAL_POOL_K=40
MEMORI_RECENT_CONVERSATIONS=10
MEMORI_SIMILAR_CONVERSATIONS=10

# Importance weights.
MEMORI_WEIGHT_IDENTITY=0.95
MEMORI_WEIGHT_GLOBAL_PREFERENCE=0.90
MEMORI_WEIGHT_ACTIVE_PROJECT=0.80
MEMORI_WEIGHT_USEFUL_FACT=0.60
MEMORI_WEIGHT_UNCERTAIN=0.35

# Ranking formula weights.
MEMORI_RANK_SEMANTIC_WEIGHT=0.70
MEMORI_RANK_IMPORTANCE_WEIGHT=0.20
MEMORI_RANK_RECENCY_WEIGHT=0.07
MEMORI_RANK_USAGE_WEIGHT=0.03
MEMORI_RANK_GLOBAL_SCOPE_BOOST=0.10
